PORT=3001
DATABASE_URL="file:./prisma/dev.db"
# Optional: comma-separated CORS origins for non-local environments
# CORS_ORIGIN=https://your-frontend-domain.com
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox
# Optional: comma-separated list from transactions,auth,identity,investments,liabilities,signal,transfer
PLAID_PRODUCTS=transactions
# Optional: comma-separated country codes
PLAID_COUNTRY_CODES=US
# Optional redirect URI for hosted Link flows
# PLAID_REDIRECT_URI=http://localhost:3001/oauth/callback
# At least 32 characters used for encrypting Plaid access tokens at rest
APP_ENCRYPTION_KEY=replace_with_a_long_random_secret_minimum_32_characters
# For this MVP we use a single local user id.
USER_ID=local-user
