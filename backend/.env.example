PORT=3001
DATABASE_URL="file:./prisma/dev.db"
# Optional: comma-separated CORS origins for non-local environments
# CORS_ORIGIN=https://your-frontend-domain.com
# Plaid has Sandbox (test data) and Production (live data)—there is no separate "staging" env.
# For dev/staging workflows use Sandbox only: sandbox secret + PLAID_ENV=sandbox. Do not use your production secret until you intentionally switch to live data (PLAID_ENV=production).
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_sandbox_secret
PLAID_ENV=sandbox
# Optional: comma-separated list from transactions,auth,identity,investments,liabilities,signal,transfer
PLAID_PRODUCTS=transactions
# Optional: comma-separated country codes
PLAID_COUNTRY_CODES=US
# Optional redirect URI for hosted Link flows
# PLAID_REDIRECT_URI=http://localhost:3001/oauth/callback
# At least 32 characters used for encrypting Plaid access tokens at rest
APP_ENCRYPTION_KEY=replace_with_a_long_random_secret_minimum_32_characters
# For this MVP we use a single local user id.
USER_ID=local-user

# Optional: AI categorization via Gemini (recommended low-cost default model)
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.0-flash-lite
